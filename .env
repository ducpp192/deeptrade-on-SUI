# ============================================================
#  Funding Arb Bot — .env config
#  Copy file này → .env và điền thông tin
# ============================================================

# Binance Futures API
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Sui Wallet (private key dạng hex, 64 chars)
SUI_PRIVATE_KEY=your_sui_private_key_hex

# Sui RPC endpoint (dùng public hoặc tự chạy node)
SUI_RPC_URL=https://fullnode.mainnet.sui.io

# DeepTrade contract address trên Sui mainnet
DEEPTRADE_PACKAGE_ID=0x1234...  # Lấy từ deeptrade.io docs

# Cấu hình bot
SYMBOL=SUI                      # Token muốn arb
MIN_FUNDING_DIFF=0.0001         # Chênh lệch funding tối thiểu để vào lệnh (0.01%)
POSITION_SIZE_USDC=100          # Mỗi leg bao nhiêu USDC
MAX_POSITION_USDC=500           # Tổng exposure tối đa
MARGIN_SAFETY=1.5               # Giữ margin >= 150%
LEG_TIMEOUT_MS=500              # Timeout nếu leg 2 không fill
